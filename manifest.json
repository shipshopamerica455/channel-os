{
  "manifest_version": 3,
  "name": "Kimi Extension",
  "version": "1.0",
  "description": "Organize Kimi.ai chats into folders and add efficiency tools.",
  "permissions": ["storage", "tabs"],
  "content_scripts": [
    {
      "matches": ["https://kimi.moonshot.cn/*", "https://www.kimi.com/*"],
      "js": ["content.js"],
      "css": ["style.css"] 
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}